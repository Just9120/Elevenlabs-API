APP_PUBLIC_URL=https://studio.librechat.online

# Stateful platform-only secret file paths. Values are file paths, not secret contents.
STUDIO_POSTGRES_PASSWORD_FILE=/path/to/studio_postgres_password
STUDIO_CREDENTIAL_MASTER_KEY_FILE=/path/to/studio_credential_master_key

# Temporary source upload storage. Values ending in _FILE are paths to operator-managed secret files, not secret contents.
STUDIO_SOURCE_S3_ENDPOINT_URL=https://example-r2-or-s3-endpoint
STUDIO_SOURCE_S3_REGION=auto
STUDIO_SOURCE_S3_BUCKET=studio-source-temp
STUDIO_SOURCE_S3_ACCESS_KEY_ID_FILE=/path/to/studio_source_s3_access_key_id
STUDIO_SOURCE_S3_SECRET_ACCESS_KEY_FILE=/path/to/studio_source_s3_secret_access_key
STUDIO_SOURCE_UPLOAD_TTL_SECONDS=3600
STUDIO_SOURCE_PRESIGN_TTL_SECONDS=900
STUDIO_SOURCE_MAX_UPLOAD_BYTES=536870912
