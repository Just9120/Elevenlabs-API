APP_PUBLIC_URL=https://studio.librechat.online

# Stateful platform-only secret file paths. Values are file paths, not secret contents.
STUDIO_POSTGRES_PASSWORD_FILE=/path/to/studio_postgres_password
STUDIO_CREDENTIAL_MASTER_KEY_FILE=/path/to/studio_credential_master_key

# Temporary source upload storage. Values ending in _FILE are paths to operator-managed secret files, not secret contents.
STUDIO_SOURCE_S3_ENDPOINT_URL=__REQUIRED_TEMP_SOURCE_S3_ENDPOINT_URL__
STUDIO_SOURCE_S3_REGION=__REQUIRED_TEMP_SOURCE_S3_REGION__
STUDIO_SOURCE_S3_BUCKET=__REQUIRED_TEMP_SOURCE_S3_BUCKET__
STUDIO_SOURCE_S3_ACCESS_KEY_ID_FILE=/path/to/studio_source_s3_access_key_id
STUDIO_SOURCE_S3_SECRET_ACCESS_KEY_FILE=/path/to/studio_source_s3_secret_access_key
# Pending uploads expire after one hour; verified local sources are retained for one day by default.
STUDIO_SOURCE_UPLOAD_TTL_SECONDS=3600
STUDIO_SOURCE_RETENTION_TTL_SECONDS=86400
STUDIO_SOURCE_PRESIGN_TTL_SECONDS=900
STUDIO_SOURCE_MAX_UPLOAD_BYTES=536870912

# Google OAuth config. Values ending in _FILE are file paths only, not secret contents.
STUDIO_GOOGLE_OAUTH_CLIENT_ID=__REQUIRED_GOOGLE_OAUTH_CLIENT_ID__
STUDIO_GOOGLE_OAUTH_CLIENT_SECRET_FILE=
STUDIO_GOOGLE_OAUTH_REDIRECT_URI=https://studio.librechat.online/api/google/oauth/callback
STUDIO_GOOGLE_OAUTH_SCOPES=openid email https://www.googleapis.com/auth/drive.file
STUDIO_GOOGLE_OAUTH_STATE_TTL_SECONDS=600
STUDIO_GOOGLE_PICKER_API_KEY=__REQUIRED_PUBLIC_RESTRICTED_PICKER_API_KEY__
STUDIO_GOOGLE_PICKER_APP_ID=__REQUIRED_GOOGLE_CLOUD_PROJECT_NUMBER__

# Studio worker runtime controls. These are not secrets.
STUDIO_WORKER_POLL_INTERVAL_SECONDS=5
STUDIO_WORKER_ERROR_BACKOFF_SECONDS=5
STUDIO_WORKER_LEASE_TTL_SECONDS=3600
STUDIO_WORKER_LEASE_HEARTBEAT_INTERVAL_SECONDS=60
